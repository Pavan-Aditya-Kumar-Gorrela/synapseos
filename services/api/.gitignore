# .gitignore

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment Variables — NEVER commit these ────────────────────────────────
.env
.env.*
!.env.example   # ← The example template IS committed

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.coverage

# ── Docker ────────────────────────────────────────────────────────────────────
# Don't ignore docker-compose.yml — it's part of the project

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
